# Copia este archivo a .env.local y completa los valores reales.
# .env.local está gitignored — nunca commitear claves.

# Supabase (proyecto Tlalocan)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Webhooks de n8n
# - VALIDACION_PAGO: lo llama la app cuando Admin valida o rechaza un comprobante;
#   el workflow notifica al huésped por WhatsApp.
#   Producción: https://reservalia.app.n8n.cloud/webhook/notificar-validacion-pago
# - NUEVA_RESERVA: reservado para futuro disparo desde la app al crear reserva manual.
VITE_N8N_WEBHOOK_NUEVA_RESERVA=
VITE_N8N_WEBHOOK_VALIDACION_PAGO=
